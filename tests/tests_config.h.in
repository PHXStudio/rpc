#pragma once
/** Absolute path to dotnet when cross-language tests are enabled. */
#define RPC_TEST_DOTNET_EXE "@RPC_TEST_DOTNET_ABS@"
/** Built CrossLangVerifier assembly (from `dotnet build` in CMake). */
#define RPC_TEST_VERIFIER_DLL "@RPC_TEST_VERIFIER_DLL_ABS@"
/** Built FullCrossLangVerifier assembly. */
#define RPC_TEST_FULL_VERIFIER_DLL "@RPC_TEST_FULL_VERIFIER_DLL_ABS@"
/** Absolute path to rpc compiler executable. */
#define RPC_TEST_COMPILER_EXE "@RPC_TEST_COMPILER_EXE@"
/** Schema directory for test .rpc files. */
#define RPC_TEST_SCHEMA_DIR "@RPC_TEST_SCHEMA_DIR@"
/** Directory for compiler test output. */
#define RPC_TEST_OUTPUT_DIR "@RPC_TEST_OUTPUT_DIR@"
