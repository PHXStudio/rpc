/* FullTest.rpc - Comprehensive schema for serialization tests.
   Based on bin/Import.rpc, covers all schema language features. */

// Single line comment.
/* Multi-line comment. */

/* Enumeration definition. */
enum EnumName
{
	EN1,
	EN2,
	EN3,
};

/* struct with skipcomp: no field mask compression. */
struct StructType (skipcomp)
{
	string aaa_;
	int32 bbb_;
};

/* struct with all field types. */
struct StructBase
{
	/* basic scalars */
	double 	double_;
	float	float_;
	int64	int64_;
	uint64	uint64_;
	int32	int32_;
	uint32	uint32_;
	int16	int16_;
	uint16	uint16_;
	int8	int8_;
	uint8	uint8_;
	bool	bool_;
	/* enum type */
	EnumName enum_;
	/* nested struct type */
	StructType struct_;
	/* dynamic string (max 65535) */
	string	string_;
	/* fixed-length string */
	string[32]	string1_;
	/* dynamic arrays */
	array<double> 	doubleArray_;
	array<float>	floatArray_;
	array<int64>	int64Array_;
	array<uint64>	uint64Array_;
	array<int32>	int32Array_;
	array<uint32>	uint32Array_;
	array<int16>	int16Array_;
	array<uint16>	uint16Array_;
	array<int8>		int8Array_;
	array<uint8>	uint8Array_;
	array<bool>		boolArray_;
	array<string> 	strArray_;
	array<EnumName> enumArray_;
	array<StructType> structArray_;
	/* fixed-size array */
	array[8]<string[16]> strarray1_;
	/* bytes (equivalent to array<uint8>) */
	bytes	bytes_;
	/* fixed-size bytes */
	bytes[64] bytes11_;
};

/* struct inheritance */
struct DerivedStruct : StructBase
{
	int32 aaa_;
};

/* service definition - all scalar + complex types */
service ServiceBase
{
	/* all scalar types */
	method1(string[32] username, string[32] password);
	/* struct parameter */
	method2(StructBase s);
	/* individual scalars */
	method3(double d, float f, int64 i64, uint64 u64);
	/* more scalars */
	method4(int32 i32, uint32 u32, int16 i16, uint16 u16);
	/* remaining scalars + bool + enum */
	method5(int8 i8, uint8 u8, bool b, EnumName e);
	/* fixed-length string + bytes */
	method6(string[16] fixedStr, bytes data);
	/* array parameters */
	method7(array<int32> ints, array<string> strs);
	/* struct array */
	method8(array<StructType> structs);
};

/* service inheritance */
service DerivedService : ServiceBase
{
	/* derived struct + no-arg method */
	method9(DerivedStruct d);
	method10();
};
